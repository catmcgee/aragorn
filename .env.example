# Aragorn — environment (BUILD_SPEC §9, amended: no mainnet fork)
# Copy to .env.local and fill in.

# ── identity plane: real ENS on Sepolia ───────────────────────────────────────
SEPOLIA_RPC_URL=                # Alchemy/Infura Sepolia endpoint
SEPOLIA_DEPLOYER_KEY=           # funded key: ENS registration + resolver deploys

# ── Privy: auth + Earn (real Base) ────────────────────────────────────────────
PRIVY_APP_ID=
PRIVY_APP_SECRET=
PRIVY_EARN_CHAIN=base
PRIVY_EARN_VAULT_ID=            # dashboard → Wallet infrastructure → Earn
PRIVY_EARN_WALLET_ID=           # created by scripts (server wallet)
PRIVY_EARN_WALLET_ADDRESS=

# ── settlement plane: local Anvil (gates start their own on :8546) ───────────
# RPC_URL=http://127.0.0.1:8546
# NOTE_REGISTRY_ADDR= / SHIELD_VAULT_ADDR= / USDC_ADDR=  — from contracts/deployments.local.json

# ── per-Ring (set by gate scripts / provision-ring; documented for reference) ─
# RING_ORG_NAME=UBS  RING_ENS=ubs.aragornrings.eth  PORT=4001
# DATABASE_URL=postgres://aragorn:aragorn@127.0.0.1:5434/ring_ubs
# PARTY_KEYS={"treasury":"0x111","trading":"0x112"}   # grumpkin scalars
# ORG_ENC_PRIV=                                        # X25519, 32B hex
# BISCUIT_ROOT_PRIV=ed25519-private/<hex>
# GATEWAY_SIGNER_KEY=                                  # CCIP response signing (secp256k1)
# EMAIL_DOMAIN_ALLOWLIST=ubs-demo.com,privy.io
# RELAYER_URL=http://127.0.0.1:4900  RELAYER_TOKEN=ubs-relay-token
# API_TOKEN=ubs-api-token                              # bootstrap service credential
# FUNDING_EOA_PRIVATE_KEY=                             # public-plane USDC wallet
# ENABLED_MODULES=payments,repo,payroll,issuance,strategies

# ── coordinator ───────────────────────────────────────────────────────────────
# RELAYER_PRIVATE_KEY=                                 # pays gas for all settles

# ── dashboard ─────────────────────────────────────────────────────────────────
# NEXT_PUBLIC_PRIVY_APP_ID=                            # same Privy app
